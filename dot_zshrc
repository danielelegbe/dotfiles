export PATH=/opt/homebrew/bin:$PATH
alias air='$(go env GOPATH)/bin/air'


# bun completions
[ -s "/Users/danielelegbe/.bun/_bun" ] && source "/Users/danielelegbe/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# pnpm
export PNPM_HOME="/Users/danielelegbe/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# sst
export PATH=/Users/danielelegbe/.sst/bin:$PATH


# neovim-remote
if [ -n "$NVIM_LISTEN_ADDRESS" ]; then
    alias nvim=nvr -cc split --remote-wait +'set bufhidden=wipe'
fi

export VISUAL="nvim"
export EDITOR="nvim"

if [[ -r /proc/version ]] && grep -qEi "(Microsoft|WSL)" /proc/version &> /dev/null; then
  # We are in WSL, run the brew shellenv command
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# editor
alias vim='nvim'

# fzf
eval "$(starship init zsh)"
source <(fzf --zsh)
#zoxide
eval "$(zoxide init --cmd cd zsh)"



source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
# Disable underline
(( ${+ZSH_HIGHLIGHT_STYLES} )) || typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[path]=none
ZSH_HIGHLIGHT_STYLES[path_prefix]=none

# Activate autosuggestions
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

if [[ ! -r /proc/version ]] || ! grep -qEi "(Microsoft|WSL)" /proc/version &> /dev/null; then
    PATH="$PATH:/Applications/WezTerm.app/Contents/MacOS"
    export PATH
fi

alias lg="lazygit"
alias ld="lazydocker"

if [ -f "$HOME/.secrets/api_keys" ]; then
    source "$HOME/.secrets/api_keys"
fi


fpath=(~/.zsh/completions $fpath)
autoload -U compinit && compinit

alias sc='sesh connect $(sesh list | fzf)'

# fnm usage
eval "$(fnm env --use-on-cd --shell zsh)"

